# Dependencies (installed fresh in Docker)
node_modules
backend/node_modules
**/node_modules

# Dev files
*.log
npm-debug.log*
nodemon.json
.nodemonignore

# Git
.git
.gitignore

# Env files (injected via Railway/compose env vars)
.env
.env.*
!.env.example

# Test / docs
*.test.js
*.spec.js
README.md
HOW_TO_RUN_LOCALLY.md

# OS
.DS_Store
Thumbs.db

# Uploads (mounted as volume in production)
backend/uploads/*
!backend/uploads/.gitkeep

# Build artifacts
dist/
build/
